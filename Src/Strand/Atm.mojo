# Atm.mojo -----------------------------------------------------------------------------------------------------------------------

from std.atomic import Atomic

#----------------------------------------------------------------------------------------------------------------------------------
 

#----------------------------------------------------------------------------------------------------------------------------------
 
struct Atm[ is_atomic: Bool, dtype: DType]:  
    var     _Data: Atomic[ Self.dtype]  

    def __init__(out self, value: Scalar[Self.dtype]):
        self._Data = Atomic[ Self.dtype]( value)
     